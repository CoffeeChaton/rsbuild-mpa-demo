{
	"js/ts.experimental.useTsgo": true,
	"js/ts.tsdk.promptToUseWorkspaceVersion": true,
	"files.associations": {
		"settings.json": "jsonc",
		"tsconfig.json": "jsonc",
		"dprint.json": "jsonc",
		".knip.jsonc": "jsonc",
		".oxlintrc.json": "jsonc",
	},
	"json.schemas": [
		{
			"fileMatch": [
				"*.jsonc",
				"dprint.json",
				".oxlintrc.json",
			],
			"schema": {
				"allowTrailingCommas": true,
			},
		},
	],
	"files.eol": "\n",
	"explorer.fileNesting.enabled": false,
	"js/ts.tsdk.path": "node_modules/typescript/lib",
	"[typescript]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4,
	},
	"[typescriptreact]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4,
	},
}
