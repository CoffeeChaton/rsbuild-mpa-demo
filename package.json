{
	"name": "rsbuild-mpa-demo",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"// ➜ 1. core": "",
		"dev": "rsbuild dev",
		"prebuild": "pnpm run qc",
		"build": "rsbuild build",
		"preview": "rsbuild preview",
		"// ➜ 2. QC": "",
		"lint": "oxlint -f=stylish && eslint . --cache",
		"lint:fix": "oxlint --fix -f=stylish && eslint . --cache --fix",
		"format": "dprint fmt",
		"test": "vitest run",
		"qc": "pnpm run format && pnpm run test && pnpm run typecheck && pnpm run lint",
		"// ➜ 3. Type": "",
		"watch:tsgo": "tsgo -b -w",
		"watch:tsc": "tsc -b -w",
		"typecheck": "tsgo -b",
		"// ➜ 4. Utilities": "",
		"tools:toAI": "pnpm dlx repomix@1.12.0 src/pages/game2/types  --compress",
		"tools:knip": "knip --no-config-hints",
		"ci:knip": "knip --include files --include dependencies --no-config-hints",
		"// ➜ 5. hooks": "",
		"prepare": "husky",
		"pre-commit": "pnpm run qc"
	},
	"scripts_vault": {
		"// ➜ XX. only pnpm dlx": "",
		"scripts:compile-materials": "tsx scripts/compile-materials.ts",
		"run_nolyfill": "pnpm dlx nolyfill@1.0.44",
		"show_cycles": "pnpm dlx skott@0.35.7 -m file-tree -e .{ts,tsx} -s",
		"get_slow_type": "pnpm dlx tsc-shame@0.2.14"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/themes": "^3.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"foxact": "^0.3.0",
		"lucide-react": "^1.8.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hotkeys-hook": "^5.2.4",
		"react-router": "^7.14.1",
		"sonner": "^2.0.7",
		"swr": "^2.4.1",
		"tailwind-merge": "^3.5.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^4.2.3",
		"@eslint/js": "^10.0.1",
		"@rsbuild/core": "^1.7.5",
		"@rsbuild/plugin-react": "^1.4.6",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260414.1",
		"dprint": "^0.54.0",
		"eslint": "^10.2.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"knip": "^6.4.1",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.21.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"overrides": {
			"vite": "npm:rolldown-vite@latest"
		},
		"onlyBuiltDependencies": [
			"core-js",
			"dprint",
			"esbuild"
		]
	}
}
