{
	"name": "rsbuild-mpa-demo",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx,json,md}": [
			"dprint fmt",
			"eslint --cache"
		]
	},
	"scripts": {
		"// ➜ 1. core": "",
		"dev": "rsbuild dev",
		"build": "rsbuild build",
		"preview": "rsbuild preview",
		"// ➜ 2. QC": "",
		"lint": " eslint . --cache",
		"format": "dprint fmt",
		"test": "vitest",
		"knip": "knip",
		"// ➜ 3. Type": "",
		"watch:tsgo": "tsgo -b -w",
		"watch:tsc": "tsc -b -w",
		"// ➜ 4. Utilities": "",
		"toAI": "pnpm dlx repomix src/pages/game2/types  --compress",
		"// ➜ 5. hooks": "",
		"prepare": "husky",
		"commit:typecheck": "pnpm tsgo -b",
		"commit:test": "vitest run",
		"pre-commit": "lint-staged && pnpm run \"/^commit:.*/\""
	},
	"scripts_vault": {
		"scripts:compile-materials": "tsx scripts/compile-materials.ts",
		"run_nolyfill": "nolyfill install",
		"show_cycles": "skott -m file-tree -e .{ts,tsx} -s",
		"get_slow_type": "tsc-shame"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/themes": "^3.3.0",
		"@types/leaflet": "^1.9.21",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"foxact": "^0.2.55",
		"leaflet": "^1.9.4",
		"lucide-react": "^0.577.0",
		"monaco-editor": "^0.55.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hotkeys-hook": "^5.2.4",
		"react-router": "^7.13.1",
		"shadcn": "^4.0.4",
		"swr": "^2.4.1",
		"tailwind-merge": "^3.5.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@rsbuild/core": "^1.7.1",
		"@rsbuild/plugin-react": "^1.4.2",
		"@rsdoctor/rspack-plugin": "^1.5.4",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260314.1",
		"dprint": "^0.52.0",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"knip": "^5.86.0",
		"lint-staged": "^16.4.0",
		"nolyfill": "^1.0.44",
		"repomix": "^1.12.0",
		"skott": "^0.35.7",
		"tailwindcss": "^4.1.18",
		"tsc-shame": "^0.2.14",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.0"
	}
}
