{
  "name": "rsbuild-mpa-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md}": [
      "dprint fmt",
      "eslint --cache"
    ]
  },
  "scripts": {
    "scripts:compile-materials": "tsx scripts/compile-materials.ts",
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "lint": "TIMING=1 eslint . --cache",
    "format": "dprint fmt",
    "typecheck": "tsgo -b",
    "toAI": "pnpm dlx repomix src/pages/game2  --compress",
    "test": "vitest",
    "preview": "rsbuild preview",
    "watch:tsgo": "tsgo -b -w",
    "commit:typecheck": "tsgo -b",
    "commit:test": "vitest",
    "pre-commit": "lint-staged && pnpm run \"/^commit:.*/\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "dprint": "^0.52.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.1.18",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.0"
  }
}
