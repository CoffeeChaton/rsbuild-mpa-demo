{
  "name": "rsbuild-mpa-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "pnpm run prebuild && pnpm rsbuild build && tsx scripts/ssg.ts",
    "build:live": "pnpm build && tsx scripts/post-build-live.ts && pnpm dlx serve dist",
    "dev": "rsbuild dev --open",
    "lint": "eslint .",
    "toAI": "pnpm dlx repomix src/pages/game",
    "preview": "rsbuild preview",
    "watch:tsc": "tsc -b -w",
    "type-check": "tsc -b"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "tsx": "^4.21.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
