{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],
		"noEmit": true
	},
	"include": [
		"rsbuild.config.ts",
		"scripts/**/*.ts",
		"shared/**/*.ts",
		"src/common/config/pages.ts"
	]
}
